:80 {
    handle /api/files* {
        respond 404
    }

    handle /api/* {
        reverse_proxy backend:8000
    }

    handle /docs* {
        reverse_proxy backend:8000
    }

    handle /openapi.json {
        reverse_proxy backend:8000
    }

    handle /files* {
        @denied not remote_ip private_ranges
        respond @denied 403
        reverse_proxy frontend:5173
    }

    handle {
        reverse_proxy frontend:5173
    }
}