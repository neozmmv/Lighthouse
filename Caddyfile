:80 {
    handle /api/files* {
        respond 404
    }

    handle /api/* {
        reverse_proxy backend:8000
    }

    handle /docs* {
        reverse_proxy backend:8000
    }

    handle /openapi.json {
        reverse_proxy backend:8000
    }

    handle /files* {
        respond 403
    }

    # MinIO bucket proxy — presigned upload/download URLs use the onion address on port 80
    handle /lighthouse/* {
        reverse_proxy minio:9000 {
            header_up Host {host}
        }
    }

    handle {
        reverse_proxy frontend:5173
    }
}

# files management — only reachable from the host machine
:8080 {
    reverse_proxy frontend:5173
}
